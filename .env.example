# Copy this file to .env and fill in the real values: cp .env.example .env
# .env is gitignored and must never be committed.

# API key for OpenCode Zen Go (LLM provider used for activity extraction).
OPENCODE_API_KEY=

# Base URL for the OpenCode Zen Go OpenAI-compatible API.
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Model used for extraction. Keep as deepseek-v4-flash (cheap) unless you've
# checked OpenCode Zen Go pricing for alternatives — cost control is a
# deliberate design constraint of this project.
OPENCODE_MODEL=deepseek-v4-flash

# Só usado pelo script de import retroativo (app/scripts/import_export.py) para legendar
# imagens/PDFs escaneados. Modelo separado do pipeline de texto ao vivo, mas ainda no
# plano Go (sem custo extra fora da assinatura) — kimi-k2.7-code tem visão real,
# testado empiricamente (glm-5.2 recusa imagem; outros modelos do Go não têm visão).
OPENCODE_VISION_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_VISION_MODEL=kimi-k2.7-code

# WhatsApp group ID for the "alunos" (students) group.
# Leave blank on first run: the bot will print all available group IDs and
# exit so you can copy the correct one here.
WHATSAPP_GROUP_ID_ALUNOS=

# WhatsApp group ID for the "profs" (professors/official announcements) group.
WHATSAPP_GROUP_ID_PROFS=

# Path to the shared SQLite database, resolved relative to the repo root by
# both the bot (Node) and the app (Python).
DB_PATH=./data/app.db

# Token gratuito da Hugging Face (huggingface.co/settings/tokens) — evita rate
# limit no download do modelo faster-whisper usado no import retroativo.
HF_TOKEN=

# Express server port for the unified backend
PORT=3000

# Node environment
NODE_ENV=development
