{
  "name": "ads-painel",
  "version": "1.0.0",
  "description": "ADS announcements panel with WhatsApp bot and OpenUI interface",
  "type": "module",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:frontend": "vite",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc",
    "build:frontend": "vite build",
    "bot": "tsx src/bot/index.ts",
    "start": "node dist/server/server.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "whatsapp-web.js": "^1.25.0",
    "qrcode-terminal": "^0.12.0",
    "axios": "^1.6.7",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/better-sqlite3": "^7.6.8",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vite": "^5.0.10",
    "concurrently": "^8.2.2"
  }
}
